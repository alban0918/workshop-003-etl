# Supabase PostgreSQL connection string
# Settings -> Database -> Connection string -> URI mode
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# Upstash Kafka (free tier — upstash.com)
# Console -> Kafka cluster -> Details
KAFKA_BOOTSTRAP_SERVERS=xxxx.upstash.io:9092
KAFKA_API_KEY=YOUR_UPSTASH_USERNAME
KAFKA_API_SECRET=YOUR_UPSTASH_PASSWORD
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_TOPIC=happiness-predictions
KAFKA_GROUP_ID=happiness-consumer-group
